{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "11ty static docs site for .agents skills",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "clean": "rm -rf _site .cache",
    "sass:build": "sass src/_scss/:src/assets/css/ --style=expanded --no-source-map",
    "sass:watch": "sass --watch src/_scss/:src/assets/css/ --style=expanded --no-source-map",
    "prebuild": "yarn sass:build && node scripts/build-search-index.mjs && npx @11ty/eleventy --dryrun",
    "dev": "yarn clean && yarn prebuild && concurrently --kill-others --names 11ty,sass \"npx @11ty/eleventy --serve\" \"yarn sass:watch\"",
    "build": "yarn clean && yarn prebuild && npx @11ty/eleventy",
    "validate:skills": "node scripts/validate-skill-frontmatter.mjs",
    "lint": "eslint . && prettier --check . && yarn validate:skills",
    "format": "prettier --write .",
    "test": "yarn build && node tests/run-all.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@eslint/js": "^9.39.4",
    "autoprefixer": "^10.5.0",
    "clean-css": "^5.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "luxon": "^3.7.2",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "4.5.0",
    "markdown-it-eleventy-img": "^0.10.2",
    "markdown-it-highlightjs": "^4.3.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "slugify": "^1.6.9",
    "uglify-js": "^3.19.3"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "posthtml": "^0.16.7"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
