<aside class="sidebar">
  {% include "partials/search-box.njk" %}

  {% if page.url and page.url.indexOf('/skills/') == 0 and skills.length !== 0 %}
  <h2>Skills</h2>
  <ul>
    {% for skill in skills %}
    <li><a href="/skills/{{ skill.slug }}/">{{ skill.name }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}
</aside>
