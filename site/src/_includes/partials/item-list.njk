<ul class="item-list {{ listName }}-list">
{% for item in items %}
  <li class="item-list--item {{ listName }}-list--item"{% if listName == 'skill' %} data-category="{{ item.category }}"{% endif %}>
    {% if listName == "guide" %}
      <h2 class="h4-style"><a href="{{ item.url }}">{{ item.data.title }}</a></h2>
      {{ item.data.page.excerpt | markdown | safe }}
    {% elif listName == "changelog" %}
      <h2 class="h4-style"><a href="{{ item.url }}">{{ item.data.date | readableDate }}</a></h2>
      {{ item.page.excerpt | safe }}
    {% elif listName == "skill" %}
      <h2 class="h4-style"><a href="/skills/{{ item.slug }}/">{{ item.name }}</a></h2>
      <p>{{ item.description }}</p>
    {% endif %}
  </li>
{% endfor %}
</ul>
